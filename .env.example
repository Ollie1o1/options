# Copy this file to .env and fill in your keys.
# .env is gitignored — never commit the real .env file.

# OpenRouter API key — default / fallback models (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-...

# Per-model keys (used when a model requires a different account/key)
OPENROUTER_ARCEE_KEY=sk-or-v1-...   # arcee-ai/trinity-large-preview:free
OPENROUTER_HUNTER_KEY=sk-or-v1-...  # openrouter/hunter-alpha

# Anthropic API key — only needed if you switch provider back to "anthropic"
# ANTHROPIC_API_KEY=sk-ant-...
