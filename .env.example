# AI ranking layer (ai_rank.py) — free account at openrouter.ai, no card required
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Optional: per-model keys for specialised free-tier models (see README ->
# "The AI Ranking Layer" for the model list). Falls back to OPENROUTER_API_KEY
# if unset.
# OPENROUTER_ARCEE_KEY=sk-or-v1-...
# OPENROUTER_STEPFUN_KEY=sk-or-v1-...
# OPENROUTER_NVIDIA_KEY=sk-or-v1-...

# Optional: use the Anthropic API directly instead of OpenRouter (also update
# provider + api_key_env in src/config_ai.py)
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: Polygon.io for higher-quality ticker-filtered news, real-time VWAP,
# and unusual options flow. Free key at polygon.io/dashboard/signup. The
# screener runs identically without it.
# POLYGON_API_KEY=your_polygon_key_here

# Free key for historical options backfill (python -m src.av_options --probe)
ALPHAVANTAGE_API_KEY=get_free_key_at_alphavantage.co/support

# Discord / Telegram bots (see README -> "API + Discord & Telegram Bots")
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=your_server_id_for_instant_sync
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
API_HOST=127.0.0.1
API_PORT=8000
API_BASE_URL=http://127.0.0.1:8000
