# Copy this file to .env and fill in your keys.
# .env is gitignored — never commit the real .env file.

# OpenRouter API key — default / fallback models (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-...

# Per-model keys (used when a model requires a different account/key)
OPENROUTER_ARCEE_KEY=sk-or-v1-...     # arcee-ai/trinity-large-preview:free
OPENROUTER_STEPFUN_KEY=sk-or-v1-...   # stepfun/step-3.5-flash:free
OPENROUTER_NVIDIA_KEY=sk-or-v1-...    # nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_HUNTER_KEY=sk-or-v1-...    # openrouter/hunter-alpha

# Anthropic API key — only needed if you switch provider back to "anthropic"
# ANTHROPIC_API_KEY=sk-ant-...

# Polygon.io API key — optional; enables high-quality ticker-filtered news,
# real-time VWAP, and unusual options flow detection.
# Sign up free at https://polygon.io/dashboard/signup
# POLYGON_API_KEY=your_polygon_key_here
